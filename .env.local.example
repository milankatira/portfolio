# MongoDB Connection String
NEXT_PUBLIC_MONGO_URL=mongodb://localhost:27017/portfolio

# API Configuration
# In development, this should be empty or http://localhost:3000
# In production, this should be your domain (https://www.milankatira.com)
NEXT_PUBLIC_API_URL=

# Revalidation Secret (for on-demand ISR cache invalidation)
# Generate a random secret string and keep it safe
REVALIDATE_SECRET=your-secret-token-here
